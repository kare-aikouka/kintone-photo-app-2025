<!-- app/views/layouts/application.html.erb -->

<!DOCTYPE html>
<html lang="ja" translate="no">
<head>
  <title><%= content_for(:title) || "施工写真アプリ" %></title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="theme-color" content="#2F6FD6">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="default">
  <meta name="apple-mobile-web-app-title" content="施工写真">
  <meta name="google" content="notranslate">
  <meta http-equiv="Content-Language" content="ja">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <link rel="manifest" href="/manifest.json">
  <link rel="icon" href="/icon-192.png" type="image/png">
  <link rel="apple-touch-icon" href="/icon-192.png">
  <script>
    (function () {
      const root = document.documentElement;

      try {
        const fontSize = window.localStorage.getItem("displayFontSize") || "normal";
        const outdoorMode = window.localStorage.getItem("displayOutdoorMode") === "true";

        root.classList.toggle("app-font-large", fontSize === "large");
        root.classList.toggle("app-font-xlarge", fontSize === "xlarge");
        root.classList.toggle("app-outdoor-mode", outdoorMode);
      } catch (_error) {
        root.classList.remove("app-font-large", "app-font-xlarge", "app-outdoor-mode");
      }
    })();
  </script>
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags "machines" %>
  <script>
    if ("serviceWorker" in navigator) {
      window.addEventListener("load", function () {
        navigator.serviceWorker.register("/service-worker.js").catch(function () {});
      });
    }

    (function () {
      let navigationLoaderTimer = null;

      function showNavigationLoader() {
        document.documentElement.classList.add("app-navigation-loading");
        window.clearTimeout(navigationLoaderTimer);
        navigationLoaderTimer = window.setTimeout(hideNavigationLoader, 20000);
      }

      function hideNavigationLoader() {
        window.clearTimeout(navigationLoaderTimer);
        navigationLoaderTimer = null;
        document.documentElement.classList.remove("app-navigation-loading");
      }

      function isMobileDevice() {
        const userAgent = navigator.userAgent || "";
        return /Android|iPhone|iPad|iPod/i.test(userAgent) ||
          (/Macintosh/i.test(userAgent) && navigator.maxTouchPoints > 1) ||
          (window.matchMedia && window.matchMedia("(pointer: coarse)").matches);
      }

      function redirectHome() {
        window.location.href = "/";
      }

      function closeAppOrRedirectHome() {
        window.close();
        window.setTimeout(function () {
          if (!document.hidden) redirectHome();
        }, 500);
      }

      function submitLogoutRequest(form) {
        const tokenMeta = document.querySelector("meta[name='csrf-token']");
        const token = tokenMeta ? tokenMeta.content : null;
        const headers = {
          "Accept": "application/json",
          "X-Requested-With": "XMLHttpRequest"
        };
        if (token) headers["X-CSRF-Token"] = token;

        return fetch(form.action, {
          method: "DELETE",
          credentials: "same-origin",
          headers: headers
        }).then(function (response) {
          return response.ok || response.redirected;
        });
      }

      document.addEventListener("submit", function (event) {
        const form = event.target;
        if (!form || !form.classList || !form.classList.contains("js-app-logout-form")) return;
        if (!isMobileDevice()) return;

        event.preventDefault();
        const shouldClose = window.confirm(form.dataset.mobileConfirm || "アプリを終了しますか？");
        showNavigationLoader();

        submitLogoutRequest(form).then(function (loggedOut) {
          if (!loggedOut) {
            form.submit();
            return;
          }
          if (shouldClose) {
            closeAppOrRedirectHome();
          } else {
            redirectHome();
          }
        }).catch(function () {
          form.submit();
        });
      }, true);

      document.addEventListener("click", function (event) {
        const link = event.target.closest && event.target.closest("a[href]");
        if (!link) return;
        if (event.defaultPrevented || event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) return;
        if (link.target && link.target !== "_self") return;
        if (link.hasAttribute("download")) return;

        const href = link.getAttribute("href") || "";
        if (href === "" || href[0] === "#" || href.startsWith("javascript:")) return;

        showNavigationLoader();
      }, true);

      document.addEventListener("submit", function (event) {
        if (event.defaultPrevented) return;
        if (event.target && event.target.classList && event.target.classList.contains("js-photo-upload-form")) return;
        if (event.target && event.target.classList && event.target.classList.contains("js-delete-confirm")) return;
        showNavigationLoader();
      }, true);

      window.addEventListener("load", hideNavigationLoader);
      window.addEventListener("pageshow", hideNavigationLoader);
      window.addEventListener("pagehide", hideNavigationLoader);
      document.addEventListener("visibilitychange", function () {
        if (document.visibilityState === "visible") hideNavigationLoader();
      });
    })();

    (function () {
      const FONT_KEY = "displayFontSize";
      const OUTDOOR_KEY = "displayOutdoorMode";

      function storageGet(key, fallback) {
        try {
          return window.localStorage.getItem(key) || fallback;
        } catch (_error) {
          return fallback;
        }
      }

      function storageSet(key, value) {
        try {
          window.localStorage.setItem(key, value);
        } catch (_error) {
          // ストレージが無効な端末では、その場の表示切替だけ反映する。
        }
      }

      function applyDisplaySettings(fontSize, outdoorMode) {
        const root = document.documentElement;
        root.classList.remove("app-font-large", "app-font-xlarge");
        root.classList.toggle("app-font-large", fontSize === "large");
        root.classList.toggle("app-font-xlarge", fontSize === "xlarge");
        root.classList.toggle("app-outdoor-mode", outdoorMode);
      }

      function currentSettings() {
        return {
          fontSize: storageGet(FONT_KEY, "normal"),
          outdoorMode: storageGet(OUTDOOR_KEY, "false") === "true"
        };
      }

      function syncControls(panel) {
        const settings = currentSettings();
        panel.querySelectorAll(".js-display-font-size").forEach(function (input) {
          const choice = input.closest(".js-display-choice");
          input.checked = input.value === settings.fontSize;
          if (choice) choice.classList.toggle("is-selected", input.checked);
        });

        const outdoorInput = panel.querySelector(".js-display-outdoor-mode");
        if (outdoorInput) {
          const choice = outdoorInput.closest(".js-display-choice");
          outdoorInput.checked = settings.outdoorMode;
          if (choice) choice.classList.toggle("is-selected", outdoorInput.checked);
        }
      }

      function openPanel(panel) {
        syncControls(panel);
        panel.classList.remove("hidden");
        const checkedInput = panel.querySelector("input:checked") || panel.querySelector("button");
        if (checkedInput) checkedInput.focus();
      }

      function closePanel(panel) {
        panel.classList.add("hidden");
        const opener = document.querySelector(".js-display-settings-open");
        if (opener) opener.focus();
      }

      document.addEventListener("DOMContentLoaded", function () {
        const panel = document.querySelector(".js-display-settings-panel");
        const opener = document.querySelector(".js-display-settings-open");
        if (!panel || !opener) return;

        const settings = currentSettings();
        applyDisplaySettings(settings.fontSize, settings.outdoorMode);
        syncControls(panel);

        opener.addEventListener("click", function () {
          openPanel(panel);
        });

        panel.querySelectorAll(".js-display-settings-close").forEach(function (button) {
          button.addEventListener("click", function () {
            closePanel(panel);
          });
        });

        panel.querySelectorAll(".js-display-font-size").forEach(function (input) {
          input.addEventListener("change", function () {
            const outdoorInput = panel.querySelector(".js-display-outdoor-mode");
            storageSet(FONT_KEY, input.value);
            applyDisplaySettings(input.value, outdoorInput ? outdoorInput.checked : false);
            syncControls(panel);
          });
        });

        const outdoorInput = panel.querySelector(".js-display-outdoor-mode");
        if (outdoorInput) {
          outdoorInput.addEventListener("change", function () {
            const checkedFontInput = panel.querySelector(".js-display-font-size:checked");
            const fontSize = checkedFontInput ? checkedFontInput.value : "normal";
            storageSet(OUTDOOR_KEY, String(outdoorInput.checked));
            applyDisplaySettings(fontSize, outdoorInput.checked);
            syncControls(panel);
          });
        }

        document.addEventListener("keydown", function (event) {
          if (event.key === "Escape" && !panel.classList.contains("hidden")) {
            closePanel(panel);
          }
        });
      });
    })();
  </script>
</head>
<body class="<%= body_css_classes %>">
  <% if show_app_shell? %>
    <%= render "layouts/app_shell" %>
  <% end %>

  <main class="<%= show_app_shell? ? 'app-main app-main-with-shell' : 'app-main' %>">
    <%= yield %>
  </main>
</body>
</html>

