<!-- app/views/layouts/application.html.erb -->

<!DOCTYPE html>
<html>
<head>
  <title><%= content_for(:title) || "Kintone Photo App 2025" %></title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags "machines" %>
</head>
<body class="<%= body_css_classes %>">
  <% if show_app_shell? %>
    <%= render "layouts/app_shell" %>
  <% end %>

  <main class="<%= show_app_shell? ? 'app-main app-main-with-shell' : 'app-main' %>">
    <%= yield %>
  </main>
</body>
</html>

