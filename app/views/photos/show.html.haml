- weekdays = %w[日 月 火 水 木 金 土]
- detail_return_params = { machine: params[:machine].presence || @machine_name.presence, machine_model: params[:machine_model].presence, date: params[:date].presence }.compact_blank
- back_url = @back_url.presence || photos_path(detail_return_params)

.photo-page.photo-detail-page
  .photo-header
    .photo-title
      = link_to "← 戻る", back_url
      %span.machine-title= @machine_name.presence || "施工写真詳細"

  - if @photo_error
    .alert.alert-danger.photo-alert
      %strong 施工写真詳細を取得できませんでした。
      %pre= "#{@photo_error.class}: #{@photo_error.message}"

  - if @record.present?
    .photo-record.photo-detail-summary
      .photo-record-main
        .photo-record-date
          - if record_date(@record)
            = "#{record_date(@record).month}/#{record_date(@record).day}(#{weekdays[record_date(@record).wday]})"
          - else
            = field_value(@record, :date)
        .photo-record-site= record_title(@record)
        - if record_address(@record).present?
          .photo-record-address= "【#{record_address(@record)}】"
        .photo-record-actions
          = link_to "地図", "javascript:undefined", class: "btn btn-soft disabled"
          = link_to "図面", "javascript:undefined", class: "btn btn-soft disabled"
          = link_to "写真", photo_path(record_id(@record), detail_return_params), class: "btn btn-primary-action"
          = link_to "資料UP", documents_photo_path(record_id(@record), detail_return_params), class: "btn btn-document-action"
      .photo-record-status
        %span.photo-status-line
          写真：
          %strong{ class: ("is-done" if photo_status(@record) == PhotosController::PICTURE_FLAG_DONE) }= photo_status(@record)

    - blackboard_date = blackboard_date_text(@record)
    - blackboard_project = field_value(@record, :site).presence || record_title(@record)
    - blackboard_maker = field_value(@record, :prime_contractor).presence || ""
    - blackboard_place = record_address(@record).presence || ""
    - blackboard_piles = blackboard_piles_text(@record)
    - stale_single_date = photo_status(@record) == PhotosController::PICTURE_FLAG_INCOMPLETE && record_date(@record).present? && record_date(@record) < Date.current && blackboard_date.scan("日").size == 1
    .photo-blackboard.js-photo-blackboard-config{ data: { record_id: record_id(@record) } }
      .photo-blackboard-head
        .photo-blackboard-title 電子黒板
        .photo-blackboard-summary 写真に白黒板を焼き込んで保存します
      .photo-blackboard-options
        %label.photo-blackboard-option
          = radio_button_tag :photo_blackboard_enabled, "1", true, class: "js-blackboard-enabled"
          %span 黒板あり
        %label.photo-blackboard-option
          = radio_button_tag :photo_blackboard_enabled, "0", false, class: "js-blackboard-enabled"
          %span 黒板なし
        %label.photo-blackboard-option
          = radio_button_tag :photo_blackboard_position, "left", true, class: "js-blackboard-position"
          %span 左下
        %label.photo-blackboard-option
          = radio_button_tag :photo_blackboard_position, "right", false, class: "js-blackboard-position"
          %span 右下
      .photo-blackboard-grid
        .photo-blackboard-field
          %label 工事名
          = text_field_tag :photo_blackboard_project, blackboard_project, class: "photo-blackboard-input js-blackboard-field", data: { blackboard_key: "project" }
        .photo-blackboard-field
          %label 右上表記
          = text_field_tag :photo_blackboard_kind, "様邸新築工事", class: "photo-blackboard-input js-blackboard-field", data: { blackboard_key: "kind" }
        .photo-blackboard-field
          %label 工事年月日
          = text_field_tag :photo_blackboard_date, blackboard_date, class: ["photo-blackboard-input js-blackboard-field", ("is-blackboard-stale-date" if stale_single_date)].compact.join(" "), data: { blackboard_key: "date" }
        .photo-blackboard-field
          %label 施工者
          = text_field_tag :photo_blackboard_maker, blackboard_maker, class: "photo-blackboard-input js-blackboard-field", data: { blackboard_key: "maker" }
        .photo-blackboard-field
          %label 工事場所
          = text_field_tag :photo_blackboard_place, blackboard_place, class: "photo-blackboard-input js-blackboard-field", data: { blackboard_key: "place" }
        .photo-blackboard-field
          %label 施工明細
          = text_field_tag :photo_blackboard_piles, blackboard_piles, class: "photo-blackboard-input js-blackboard-field", data: { blackboard_key: "piles" }
        .photo-blackboard-field
          %label 下部表記
          = text_field_tag :photo_blackboard_footer, "會澤高圧コンクリート(株)", class: "photo-blackboard-input js-blackboard-field", data: { blackboard_key: "footer" }
      .photo-blackboard-preview
        .photo-blackboard-preview-title 焼き付けプレビュー
        %canvas.js-blackboard-preview-canvas{ width: 800, height: 600 }
        .photo-blackboard-adjustments
          .photo-blackboard-adjustment
            %label サイズ
            %span.photo-blackboard-scale-label.js-blackboard-scale-label 標準（72%）
            = range_field_tag :photo_blackboard_scale, 72, min: 56, max: 120, step: 1, list: "blackboard-scale-steps", class: "js-blackboard-adjust", data: { blackboard_key: "scale" }
            %datalist#blackboard-scale-steps
              %option{ value: 56, label: "最小" }
              %option{ value: 64, label: "小" }
              %option{ value: 72, label: "標準" }
              %option{ value: 84, label: "やや大" }
              %option{ value: 96, label: "大" }
              %option{ value: 108, label: "特大" }
              %option{ value: 120, label: "最大" }
        %details.photo-blackboard-position-details
          %summary.photo-blackboard-position-summary 位置微調整（必要な時だけ開く）
          .photo-blackboard-position-adjustments
            .photo-blackboard-adjustment
              %label 横位置
              = range_field_tag :photo_blackboard_offset_x, -120, min: -120, max: 120, step: 5, class: "js-blackboard-adjust", data: { blackboard_key: "offsetX" }
            .photo-blackboard-adjustment
              %label 縦位置
              = range_field_tag :photo_blackboard_offset_y, 120, min: -120, max: 120, step: 5, class: "js-blackboard-adjust", data: { blackboard_key: "offsetY" }
        .photo-blackboard-reset-area
          %button.photo-blackboard-reset.js-blackboard-reset{ type: "button" } kintone値に戻す

    - @detail_sections.each do |section|
      .photo-detail-section
        - if section[:note].present?
          .photo-detail-note= section[:note]

        - section[:tables].each do |table_code|
          - rows = detail_table_rows(@record, table_code)
          - columns = detail_table_columns(rows, table_code)
          - file_column = detail_file_column(rows, columns, table_code)
          - memo_column = detail_memo_column(columns, table_code)
          - add_form_id = table_row_dom_id(table_code, "add")
          - edit_rows_id = table_row_dom_id(table_code, "edit")
          - table_save_form_id = table_row_dom_id(table_code, "save-form")
          - has_row_actions = file_column.present? || memo_column.present?
          .photo-detail-table
            .photo-detail-table-title= detail_table_label(table_code)
            .photo-detail-table-actions
              = button_tag "追加", type: "button", class: "btn photo-table-action-add js-photo-table-toggle", data: { target: add_form_id }, disabled: !has_row_actions
              = button_tag "編集", type: "button", class: "btn photo-table-action-edit js-photo-table-edit-save", data: { target: edit_rows_id, save_form: table_save_form_id }, disabled: rows.blank? || !has_row_actions
              = button_tag "キャンセル", type: "button", class: "btn photo-table-action-cancel hidden js-photo-table-edit-cancel", data: { target: edit_rows_id, edit_button_target: ".js-photo-table-edit-save[data-target='#{edit_rows_id}']", save_form: table_save_form_id }
            - if rows.present? && has_row_actions
              = form_with url: batch_table_rows_photo_path(record_id(@record), detail_return_params), method: :patch, multipart: true, local: true, html: { id: table_save_form_id, class: "photo-table-save-form js-photo-upload-form" } do
                = hidden_field_tag :table_code, table_code
                = hidden_field_tag :file_column, file_column
                = hidden_field_tag :memo_column, memo_column
            - if columns.present?
              .photo-detail-table-scroll
                %table
                  %thead
                    %tr
                      - columns.each do |column|
                        %th= detail_column_label(table_code, column)
                      - if has_row_actions
                        %th.photo-table-action-column
                  %tbody
                    - if rows.present?
                      - rows.each do |row|
                        - edit_form_id = table_row_dom_id("#{table_code}-#{row["id"]}", "form")
                        - quick_form_id = table_row_dom_id("#{table_code}-#{row["id"]}", "quick-form")
                        %tr
                          - columns.each do |column|
                            %td
                              - if detail_file_cell?(row, column)
                                - files = Array(detail_cell_value(row, column))
                                - if files.present?
                                  .photo-file-list{ class: edit_rows_id }
                                    - files.each do |file|
                                      - file_key = file["fileKey"]
                                      - content_type = file["contentType"].presence || "image/jpeg"
                                      - if file_key.present?
                                        - file_url = files_path(key: file_key, type: content_type)
                                        - previewable = content_type.start_with?("image/")
                                        = link_to file_url, class: ["photo-file", ("js-photo-preview" if previewable)].compact.join(" "), data: { preview_src: file_url, preview_name: file["name"].presence || "ファイル" } do
                                          - if content_type.start_with?("image/")
                                            = image_tag file_url, alt: file["name"]
                                          %span= file["name"].presence || "ファイル"
                                  - if column == file_column
                                    .photo-blackboard-overwrite-list.hidden{ class: edit_rows_id }
                                      - files.each do |file|
                                        - file_key = file["fileKey"]
                                        - content_type = file["contentType"].presence || "image/jpeg"
                                        - if file_key.present? && content_type.start_with?("image/")
                                          - file_url = files_path(key: file_key, type: content_type)
                                          = button_tag "黒板を修正", type: "button", class: "btn photo-blackboard-overwrite js-blackboard-overwrite", data: { src: file_url, file_name: file["name"].presence || "photo.jpg", table_code: table_code, row_id: row["id"], file_column: file_column, memo_column: memo_column, update_url: table_rows_photo_path(record_id(@record), detail_return_params) }
                                - else
                                  %span.photo-empty{ class: edit_rows_id } 未登録
                                - if column == file_column
                                  .photo-table-quick-capture{ class: edit_rows_id }
                                    = form_with url: table_rows_photo_path(record_id(@record), detail_return_params), method: :patch, multipart: true, local: true, html: { id: quick_form_id, class: "js-photo-upload-form" } do
                                      = hidden_field_tag :table_code, table_code
                                      = hidden_field_tag :row_id, row["id"]
                                      = hidden_field_tag :file_column, file_column
                                      = hidden_field_tag :memo_column, memo_column
                                      .photo-table-file-choice.js-photo-file-choice
                                        = file_field_tag :photo, accept: "image/*", capture: "environment", id: "#{quick_form_id}-camera", class: "photo-table-hidden-file js-photo-auto-submit"
                                        = label_tag "#{quick_form_id}-camera", class: "btn photo-table-capture-button" do
                                          %span.btn-icon 📷
                                        = file_field_tag :photo, accept: "image/*", id: "#{quick_form_id}-gallery", class: "photo-table-hidden-file js-photo-auto-submit"
                                        = label_tag "#{quick_form_id}-gallery", class: "btn photo-table-capture-button photo-table-gallery-button" do
                                          %span.btn-icon 🖼
                                        %span.photo-table-selected-file.js-photo-selected-file
                                  .photo-table-capture-control.hidden{ class: edit_rows_id }
                                    .photo-table-file-choice.js-photo-file-choice
                                      = file_field_tag "table_rows[#{row["id"]}][photo]", accept: "image/*", capture: "environment", id: "#{edit_form_id}-camera", class: "photo-table-hidden-file", form: table_save_form_id
                                      = label_tag "#{edit_form_id}-camera", class: "btn photo-table-capture-button" do
                                        %span.btn-icon 📷
                                      = file_field_tag "table_rows[#{row["id"]}][photo]", accept: "image/*", id: "#{edit_form_id}-gallery", class: "photo-table-hidden-file", form: table_save_form_id
                                      = label_tag "#{edit_form_id}-gallery", class: "btn photo-table-capture-button photo-table-gallery-button" do
                                        %span.btn-icon 🖼
                                      %span.photo-table-selected-file.js-photo-selected-file
                              - else
                                - value = detail_cell_value(row, column)
                                - if column == memo_column
                                  - memo_value = value.is_a?(Array) ? value.join(", ") : value
                                  - memo_is_number = number_memo_column?(rows, table_code, column)
                                  .photo-table-memo-display{ class: edit_rows_id }
                                    = detail_memo_display(memo_value, rows, table_code, column)
                                  - if memo_is_number
                                    .photo-table-number-memo.hidden{ class: edit_rows_id }
                                      %span.photo-table-number-memo-unit L=
                                      = number_field_tag "table_rows[#{row["id"]}][memo]", memo_value, step: "any", inputmode: "decimal", class: "photo-table-memo photo-table-row-memo photo-table-number-input", form: table_save_form_id
                                      %span.photo-table-number-memo-unit m
                                  - else
                                    = text_area_tag "table_rows[#{row["id"]}][memo]", memo_value, rows: 5, class: "photo-table-memo photo-table-row-memo hidden #{edit_rows_id}", form: table_save_form_id
                                - elsif value.is_a?(Array)
                                  = value.join(", ")
                                - else
                                  = value.presence || "-"
                          - if has_row_actions
                            %td.photo-table-action-column
                              .photo-table-row-actions
                                = form_with url: table_rows_photo_path(record_id(@record), detail_return_params), method: :delete, local: true, class: "photo-table-delete-form js-delete-confirm", data: { confirm_message: "この写真・メモを削除しますか？" } do
                                  = hidden_field_tag :table_code, table_code
                                  = hidden_field_tag :row_id, row["id"]
                                  = submit_tag "削除", class: "btn btn-danger-action photo-table-row-delete"
                    - else
                      %tr.photo-detail-placeholder-row
                        %td{ colspan: columns.count + (has_row_actions ? 1 : 0) } まだ登録されている行はありません。
                    - if has_row_actions
                      %tr.photo-detail-add-row.hidden{ id: add_form_id }
                        %td{ colspan: columns.count + 1 }
                          .photo-table-row-editor.photo-table-row-editor-add.photo-table-inline-editor
                            = form_with url: table_rows_photo_path(record_id(@record), detail_return_params), method: :post, multipart: true, local: true, html: { id: "#{add_form_id}-form", class: "js-photo-upload-form" } do
                              = hidden_field_tag :table_code, table_code
                              = hidden_field_tag :file_column, file_column
                              = hidden_field_tag :memo_column, memo_column
                              .photo-table-inline-grid{ style: "grid-template-columns: repeat(#{columns.count}, minmax(220px, 1fr)) minmax(96px, 120px);" }
                                - columns.each do |column|
                                  .photo-table-inline-cell
                                    - if column == file_column
                                      .photo-table-attachment-empty （添付なし）
                                      .photo-table-file-choice.js-photo-file-choice
                                        = file_field_tag :photo, accept: "image/*", capture: "environment", id: "#{add_form_id}-camera", class: "photo-table-hidden-file js-photo-auto-submit"
                                        = label_tag "#{add_form_id}-camera", class: "btn photo-table-capture-button" do
                                          %span.btn-icon 📷
                                        = file_field_tag :photo, accept: "image/*", id: "#{add_form_id}-gallery", class: "photo-table-hidden-file js-photo-auto-submit"
                                        = label_tag "#{add_form_id}-gallery", class: "btn photo-table-capture-button photo-table-gallery-button" do
                                          %span.btn-icon 🖼
                                        %span.photo-table-selected-file.js-photo-selected-file 選択されていません
                                      .photo-table-form-actions.photo-table-inline-actions
                                        = button_tag "キャンセル", type: "button", class: "btn btn-soft photo-table-cancel js-photo-table-close", data: { target: add_form_id }
                                    - elsif column == memo_column
                                      %span.photo-empty 編集ボタンで入力
                                    - else
                                      %span.photo-empty -
                                .photo-table-inline-cell.photo-table-action-column
            - else
              .photo-detail-empty
                まだ登録されている行はありません。

    - if show_debug_panels? && @field_keys.present?
      %details.photo-debug
        %summary 取得フィールド確認
        %p
          %strong フィールド:
          = @field_keys.join(", ")
        - if @field_preview.present?
          %table
            %tbody
              - @field_preview.first(40).each do |key, value|
                %tr
                  %th= key
                  %td= value

:javascript
  document.addEventListener("DOMContentLoaded", function () {
    const PHOTO_MAX_SIZE = 1280;
    const PHOTO_JPEG_QUALITY = 0.85;
    const BLACKBOARD_STALE_DATE_CHECK = #{stale_single_date ? "true" : "false"};
    const BLACKBOARD_TODAY = new Date(#{Date.current.year}, #{Date.current.month - 1}, #{Date.current.day});
    const BLACKBOARD_STORAGE_KEY = "photo-blackboard:" + window.location.pathname;
    const BLACKBOARD_PHOTO_STORAGE_KEY = "photo-blackboard-photos:" + window.location.pathname;
    const BLACKBOARD_FONT_FAMILY = '"Noto Sans CJK JP", "Noto Sans JP", "Hiragino Sans", "Yu Gothic", "Meiryo", sans-serif';
    const BLACKBOARD_MIN_SCALE = 0.56;
    const BLACKBOARD_MAX_SCALE = 1.2;
    const BLACKBOARD_OVERWRITE_SCALE = 1.03;
    const BLACKBOARD_CONFIG_VERSION = 3;
    const BLACKBOARD_DEFAULT_SCALE_VALUE = "72";
    const BLACKBOARD_SCALE_STEPS = [56, 64, 72, 84, 96, 108, 120];
    const BLACKBOARD_SCALE_LABELS = {
      56: "最小",
      64: "小",
      72: "標準",
      84: "やや大",
      96: "大",
      108: "特大",
      120: "最大"
    };

    const BLACKBOARD_SCALE_LEVELS = {
      56: "1",
      64: "2",
      72: "3",
      84: "4",
      96: "5",
      108: "6",
      120: "7"
    };

    function syncBlackboardScaleControl() {
      const input = document.querySelector(".js-blackboard-adjust[data-blackboard-key='scale']");
      const label = document.querySelector(".js-blackboard-scale-label");

      if (!input) return;

      const snapValue = function (value) {
        const numericValue = Number(value);
        const fallbackValue = Number(BLACKBOARD_DEFAULT_SCALE_VALUE);
        const currentValue = Number.isFinite(numericValue) ? numericValue : fallbackValue;

        return BLACKBOARD_SCALE_STEPS.reduce(function (nearest, step) {
          return Math.abs(step - currentValue) < Math.abs(nearest - currentValue) ? step : nearest;
        }, BLACKBOARD_SCALE_STEPS[0]);
      };

      const syncValueAndLabel = function () {
        const scaleValue = snapValue(input.value);
        input.value = scaleValue;

        if (label) {
          const scaleLabel = BLACKBOARD_SCALE_LABELS[scaleValue] || String(scaleValue);
          const levelLabel = BLACKBOARD_SCALE_LEVELS[scaleValue] || "?";
          label.textContent = scaleLabel + "（" + levelLabel + "）";
        }
      };

      input.min = BLACKBOARD_SCALE_STEPS[0];
      input.max = BLACKBOARD_SCALE_STEPS[BLACKBOARD_SCALE_STEPS.length - 1];
      syncValueAndLabel();
      input.addEventListener("input", syncValueAndLabel);
      input.addEventListener("change", syncValueAndLabel);
    }

    const deleteConfirm = buildDeleteConfirm();
    const photoPreview = buildPhotoPreview();
    const uploadIndicator = buildUploadIndicator();
    const blackboardWarning = buildBlackboardWarningDialog();
    const PHOTO_UPLOAD_STEPS = [
      { key: "prepare", label: "画像確認" },
      { key: "blackboard", label: "黒板処理" },
      { key: "send", label: "送信" },
      { key: "confirm", label: "保存確認" }
    ];
    const PHOTO_SAVE_STEPS = [
      { key: "prepare", label: "入力確認" },
      { key: "send", label: "保存" },
      { key: "confirm", label: "完了判定" }
    ];
    const scrollStorageKey = "photo-scroll:" + window.location.pathname;
    let pendingFileInput = null;
    let lastSelectedFileInput = null;
    let addRowSequence = 0;

    restorePhotoScroll();
    restoreBlackboardConfig();
    syncBlackboardScaleControl();
    sanitizeBlackboardPilesInput();
    syncBlackboardFieldDefaults();
    bindBlackboardConfig();
    updateBlackboardRequiredHighlights();
    updateBlackboardPreview();
    refreshBlackboardPreviewSoon();

    window.addEventListener("pageshow", refreshBlackboardPreviewSoon);
    window.addEventListener("resize", refreshBlackboardPreviewSoon);
    document.addEventListener("turbo:load", refreshBlackboardPreviewSoon);
    document.addEventListener("turbo:render", refreshBlackboardPreviewSoon);

    document.querySelectorAll(".js-photo-table-toggle").forEach(function (button) {
      button.addEventListener("click", function () {
        const target = document.getElementById(button.dataset.target);
        if (target) addPhotoTableRow(target);
      });
    });

    document.querySelectorAll(".js-photo-table-edit-save").forEach(function (button) {
      button.addEventListener("click", function () {
        const saveForm = document.getElementById(button.dataset.saveForm);
        if (button.dataset.mode === "save") {
          if (saveForm) submitRememberingScroll(saveForm);
          return;
        }

        setPhotoTableEditMode(button.dataset.target, true);
        button.dataset.mode = "save";
        button.textContent = "保存";
        button.classList.add("is-save");
        const cancelButton = document.querySelector(".js-photo-table-edit-cancel[data-target='" + button.dataset.target + "']");
        if (cancelButton) cancelButton.classList.remove("hidden");
      });
    });

    document.querySelectorAll(".js-photo-table-edit-cancel").forEach(function (button) {
      button.addEventListener("click", function () {
        cancelPhotoTableEdit(button);
      });
    });

    document.querySelectorAll(".js-photo-table-close").forEach(bindPhotoTableClose);

    document.querySelectorAll(".js-photo-file-choice input[type='file']").forEach(bindPhotoFileInput);
    document.querySelectorAll(".js-photo-selected-file").forEach(bindUploadRetryLabel);

    document.querySelectorAll(".js-photo-preview").forEach(function (link) {
      link.addEventListener("click", function (event) {
        event.preventDefault();
        photoPreview.open(link.dataset.previewSrc || link.href, link.dataset.previewName || "写真");
      });
    });
    document.querySelectorAll(".js-blackboard-overwrite").forEach(bindBlackboardOverwriteButton);

    window.addEventListener("focus", retryPendingFileInput);
    window.addEventListener("pageshow", retryPendingFileInput);
    document.addEventListener("visibilitychange", function () {
      if (document.visibilityState === "visible") retryPendingFileInput();
    });

    document.querySelectorAll(".js-photo-upload-form").forEach(bindPhotoUploadForm);
    document.querySelectorAll("form").forEach(bindPhotoScrollMemory);

    document.querySelectorAll(".js-delete-confirm").forEach(function (form) {
      form.addEventListener("submit", function (event) {
        event.preventDefault();
        deleteConfirm.open(form, form.dataset.confirmMessage || "削除しますか？");
      });
    });

    function addPhotoTableRow(target) {
      if (target.classList.contains("hidden")) {
        target.classList.remove("hidden");
        return;
      }

      addRowSequence += 1;
      const clone = target.cloneNode(true);
      const cloneId = target.id + "-copy-" + addRowSequence;
      clone.id = cloneId;
      clone.dataset.addSource = target.id;
      clone.classList.remove("hidden");
      resetClonedAddRow(clone, target.id, cloneId);

      const siblings = Array.from(target.parentNode.querySelectorAll("[data-add-source='" + target.id + "']"));
      const reference = siblings[siblings.length - 1] || target;
      reference.insertAdjacentElement("afterend", clone);
      bindDynamicPhotoControls(clone);
    }

    function resetClonedAddRow(row, sourceId, cloneId) {
      row.querySelectorAll("[id]").forEach(function (element) {
        element.id = element.id.replace(sourceId, cloneId);
      });

      row.querySelectorAll("label[for]").forEach(function (label) {
        label.htmlFor = label.htmlFor.replace(sourceId, cloneId);
      });

      row.querySelectorAll(".js-photo-table-close").forEach(function (button) {
        button.dataset.target = cloneId;
      });

      row.querySelectorAll("form").forEach(function (form) {
        form.dataset.uploading = "false";
        delete form.dataset.activeFileInput;
        form.removeAttribute("data-photo-upload-bound");
      });

      row.querySelectorAll("input[type='file']").forEach(function (input) {
        input.value = "";
        input.removeAttribute("data-photo-file-bound");
      });

      row.querySelectorAll("textarea").forEach(function (textarea) {
        textarea.value = "";
      });

      row.querySelectorAll(".js-photo-selected-file").forEach(function (label) {
        clearUploadError(label);
        label.removeAttribute("data-photo-retry-bound");
        label.textContent = "選択されていません";
      });

      row.querySelectorAll(".js-photo-table-close").forEach(function (button) {
        button.removeAttribute("data-photo-close-bound");
      });
    }

    function bindDynamicPhotoControls(container) {
      container.querySelectorAll(".js-photo-table-close").forEach(bindPhotoTableClose);
      container.querySelectorAll(".js-photo-file-choice input[type='file']").forEach(bindPhotoFileInput);
      container.querySelectorAll(".js-photo-selected-file").forEach(bindUploadRetryLabel);
      container.querySelectorAll(".js-blackboard-overwrite").forEach(bindBlackboardOverwriteButton);
      container.querySelectorAll(".js-photo-upload-form").forEach(bindPhotoUploadForm);
      container.querySelectorAll("form").forEach(bindPhotoScrollMemory);
    }

    function setPhotoTableEditMode(targetClass, editing) {
      const groupedTargets = document.querySelectorAll("." + targetClass);
      groupedTargets.forEach(function (element) {
        if (element.classList.contains("photo-table-quick-capture")) {
          setElementHidden(element, editing);
          return;
        }

        if (
          element.classList.contains("photo-blackboard-overwrite-list") ||
          element.classList.contains("photo-table-capture-control") ||
          element.classList.contains("photo-table-number-memo") ||
          element.classList.contains("photo-table-memo")
        ) {
          setElementHidden(element, !editing);
          return;
        }

        if (
          element.classList.contains("photo-table-memo-display") ||
          element.classList.contains("photo-empty")
        ) {
          setElementHidden(element, editing);
        }
      });
    }

    function setElementHidden(element, hidden) {
      element.classList.toggle("hidden", hidden);
    }

    function cancelPhotoTableEdit(button) {
      setPhotoTableEditMode(button.dataset.target, false);

      const groupedTargets = document.querySelectorAll("." + button.dataset.target);
      groupedTargets.forEach(function (element) {
        if (element.classList.contains("photo-blackboard-overwrite-list")) {
          element.querySelectorAll(".js-blackboard-overwrite").forEach(function (overwriteButton) {
            overwriteButton.disabled = false;
            overwriteButton.textContent = "黒板を修正";
          });
        }
      });

      const saveForm = document.getElementById(button.dataset.saveForm);
      if (saveForm) saveForm.reset();

      const editButton = document.querySelector(button.dataset.editButtonTarget || "");
      if (editButton) {
        editButton.dataset.mode = "edit";
        editButton.textContent = "編集";
        editButton.classList.remove("is-save");
      }
      button.classList.add("hidden");
    }

    function bindPhotoTableClose(button) {
      if (button.dataset.photoCloseBound === "true") return;
      button.dataset.photoCloseBound = "true";
      button.addEventListener("click", function () {
        const target = document.getElementById(button.dataset.target);
        if (!target) return;

        if (target.dataset.addSource) {
          target.remove();
        } else {
          target.classList.add("hidden");
        }
      });
    }

    function bindPhotoFileInput(input) {
      if (input.dataset.photoFileBound === "true") return;
      input.dataset.photoFileBound = "true";
      input.addEventListener("click", function (event) {
        if (!guardBlackboardBeforePhoto(event)) {
          input.value = "";
          return;
        }
        input.value = "";
        pendingFileInput = input;
      });
      input.addEventListener("input", function () {
        handleFileInput(input);
      });
      input.addEventListener("change", function () {
        handleFileInput(input);
      });
    }

    function bindPhotoUploadForm(form) {
      if (form.dataset.photoUploadBound === "true") return;
      form.dataset.photoUploadBound = "true";
      form.addEventListener("submit", async function (event) {
        const files = selectedUploadFiles(form);
        const hasFiles = files.length > 0;
        if (!hasFiles && isAutoPhotoUploadForm(form)) {
          event.preventDefault();
          return;
        }

        event.preventDefault();
        const selectedInput = activeFileInput(form);
        const selectedChoice = selectedInput && selectedInput.closest(".js-photo-file-choice");
        const selectedLabel = selectedChoice && selectedChoice.querySelector(".js-photo-selected-file");
        if (hasFiles && files.some(function (file) { return !file || file.size <= 0; })) {
          showUploadError(form, selectedInput, selectedLabel);
          alert("カメラから写真ファイルを取得できませんでした。もう一度撮影してください。");
          return;
        }
        if (hasFiles && !guardBlackboardBeforePhoto(event)) {
          if (selectedInput) selectedInput.value = "";
          if (selectedLabel) selectedLabel.textContent = "選択されていません";
          return;
        }

        if (form.dataset.uploading === "true") return;

        form.dataset.uploading = "true";
        const disabledInputs = disableInactiveChoiceInputs(form);
        const progressSteps = hasFiles ? PHOTO_UPLOAD_STEPS : PHOTO_SAVE_STEPS;
        try {
          if (hasFiles && selectedLabel) selectedLabel.textContent = "画像処理中...";
          uploadIndicator.show(
            hasFiles ? "画像を準備中..." : "保存内容を確認中...",
            hasFiles ? "写真を圧縮し、黒板情報を確認しています" : "入力内容をkintoneへ保存する準備をしています",
            { steps: progressSteps, activeStep: "prepare" }
          );
          clearUploadError(selectedLabel);
          if (hasFiles) {
            uploadIndicator.show(
              "黒板を焼き付け中...",
              "写真サイズを整えてから保存用データを作成しています",
              { steps: progressSteps, activeStep: "blackboard" }
            );
          }
          const body = hasFiles ? await compressedFormData(form) : new FormData(form);
          if (hasFiles && selectedLabel) selectedLabel.textContent = "kintoneへ送信中...";
          uploadIndicator.show(
            hasFiles ? "kintoneへ送信中..." : "kintoneへ保存中...",
            hasFiles ? "通信状況により10秒ほどかかる場合があります" : "完了フラグを再判定しています",
            { steps: progressSteps, activeStep: "send" }
          );

          const response = await fetch(form.action, {
            body: body,
            credentials: "same-origin",
            headers: { "X-Requested-With": "XMLHttpRequest" },
            method: (form.method || "post").toUpperCase()
          });

          if (!response.ok) throw new Error("upload failed");
          
          if (hasFiles && selectedInput && selectedInput.hasAttribute("capture")) {
            try {
              const file = selectedInput.files[0];
              const backupFile = await compressedBackupImageFile(file);
              downloadLocalFile(backupFile);
            } catch (backupError) {
              // エマージェンシー用保存の失敗は無視して通常処理を続行
            }
          }
          uploadIndicator.show(
            hasFiles ? "保存結果を確認中..." : "完了状態を確認中...",
            "画面を更新して最新の状態を表示します",
            { steps: progressSteps, activeStep: "confirm" }
          );
          saveUploadedBlackboardPhotoConfig(form, body);
          rememberPhotoScroll(form);
          window.location.href = response.url || window.location.href;
        } catch (error) {
          form.dataset.uploading = "false";
          restoreDisabledInputs(disabledInputs);
          uploadIndicator.hide();
          showUploadError(form, selectedInput, selectedLabel);
          if (hasFiles) {
            alert("写真を保存できなかったので端末に保存します。");
            files.filter(function (file) { return file && file.size > 0; }).forEach(downloadLocalFile);
          } else {
            alert("保存できませんでした。通信状況を確認してもう一度お試しください。");
          }
        }
      });
    }

    function bindUploadRetryLabel(label) {
      if (label.dataset.photoRetryBound === "true") return;
      label.dataset.photoRetryBound = "true";
      label.addEventListener("click", function () {
        retryUploadFromLabel(label);
      });
      label.addEventListener("keydown", function (event) {
        if (event.key !== "Enter" && event.key !== " ") return;
        event.preventDefault();
        retryUploadFromLabel(label);
      });
    }

    function retryUploadFromLabel(label) {
      if (!label.classList.contains("is-upload-error")) return;

      const input = document.getElementById(label.dataset.retryInput || "");
      if (!input) return;

      const form = input.form;
      if (form && input.files && input.files.length > 0) {
        form.dataset.activeFileInput = input.id;
        submitRememberingScroll(form);
      } else {
        input.click();
      }
    }

    function showUploadError(form, input, label) {
      if (!label) return;

      label.textContent = "貼り付けエラー（タップで再アップロード）";
      label.classList.add("is-upload-error");
      label.setAttribute("role", "button");
      label.setAttribute("tabindex", "0");
      if (input && input.id) {
        label.dataset.retryInput = input.id;
        if (form) form.dataset.activeFileInput = input.id;
      }
    }

    function clearUploadError(label) {
      if (!label) return;

      label.classList.remove("is-upload-error");
      label.removeAttribute("role");
      label.removeAttribute("tabindex");
      delete label.dataset.retryInput;
    }

    function selectedUploadFiles(form) {
      const activeInput = activeFileInput(form);
      const inputs = activeInput ? [activeInput] : formFileInputs(form);
      return inputs.flatMap(function (input) {
        return Array.from(input.files || []);
      });
    }

    function isAutoPhotoUploadForm(form) {
      return !!(form && form.querySelector(".js-photo-auto-submit"));
    }

    function rememberPhotoScroll(form) {
      const anchor = form.closest(".photo-detail-table") || form.closest("tr") || form;
      const anchorTop = anchor ? Math.max(0, Math.round(anchor.getBoundingClientRect().top + window.scrollY - 24)) : window.scrollY;
      sessionStorage.setItem(scrollStorageKey, JSON.stringify({
        anchorTop: anchorTop,
        scrollY: Math.round(window.scrollY)
      }));
    }

    function rememberElementScroll(element) {
      const anchor = element.closest(".photo-detail-table") || element.closest("tr") || element;
      const anchorTop = anchor ? Math.max(0, Math.round(anchor.getBoundingClientRect().top + window.scrollY - 24)) : window.scrollY;
      sessionStorage.setItem(scrollStorageKey, JSON.stringify({
        anchorTop: anchorTop,
        scrollY: Math.round(window.scrollY)
      }));
    }

    function bindPhotoScrollMemory(form) {
      if (form.dataset.photoScrollBound === "true") return;
      form.dataset.photoScrollBound = "true";
      form.addEventListener("submit", function () {
        rememberPhotoScroll(form);
      }, true);
    }

    function submitRememberingScroll(form) {
      rememberPhotoScroll(form);
      form.requestSubmit ? form.requestSubmit() : form.submit();
    }

    function restorePhotoScroll() {
      const raw = sessionStorage.getItem(scrollStorageKey);
      if (!raw) return;

      sessionStorage.removeItem(scrollStorageKey);
      let position;
      try {
        position = JSON.parse(raw);
      } catch (error) {
        return;
      }

      const targetY = Number.isFinite(position.anchorTop) ? position.anchorTop : position.scrollY;
      if (!Number.isFinite(targetY)) return;

      [0, 150, 500].forEach(function (delay) {
        window.setTimeout(function () {
          window.scrollTo({ top: targetY, behavior: "auto" });
        }, delay);
      });
    }

    function formFileInputs(form) {
      const inputs = Array.from(form.querySelectorAll("input[type='file']"));
      if (form.id) {
        inputs.push.apply(inputs, Array.from(document.querySelectorAll("input[type='file'][form='" + form.id + "']")));
      }
      return inputs;
    }

    function activeFileInput(form) {
      if (!form) return null;

      if (
        lastSelectedFileInput &&
        lastSelectedFileInput.form === form &&
        lastSelectedFileInput.files &&
        lastSelectedFileInput.files.length > 0
      ) {
        return lastSelectedFileInput;
      }

      if (!form.dataset.activeFileInput) return null;

      const input = document.getElementById(form.dataset.activeFileInput);
      return input && input.files && input.files.length > 0 ? input : null;
    }

    function disableInactiveChoiceInputs(form) {
      const activeInput = activeFileInput(form);
      if (!activeInput) return [];

      const choice = activeInput.closest(".js-photo-file-choice");
      if (!choice) return [];

      return Array.from(choice.querySelectorAll("input[type='file']")).filter(function (input) {
        return input !== activeInput && !input.disabled;
      }).map(function (input) {
        input.disabled = true;
        return input;
      });
    }

    function restoreDisabledInputs(inputs) {
      inputs.forEach(function (input) {
        input.disabled = false;
      });
    }

    async function compressedFormData(form) {
      const formData = new FormData(form);
      const input = activeFileInput(form);
      if (!input || !input.name || !input.files || input.files.length === 0) return formData;

      const file = input.files[0];

      let uploadFile;
      try {
        uploadFile = await compressedImageFile(file);
      } catch (error) {
        uploadFile = renamedOriginalFile(file);
      }
      formData.set(input.name, uploadFile, uploadFile.name);
      return formData;
    }

    async function compressedImageFile(file) {
      if (!file || !file.type || !file.type.startsWith("image/")) return file;

      const image = await loadImage(file);
      const size = fittedImageSize(image.width, image.height, PHOTO_MAX_SIZE);
      const canvas = document.createElement("canvas");
      canvas.width = size.width;
      canvas.height = size.height;
      const context = canvas.getContext("2d");
      context.drawImage(image, 0, 0, size.width, size.height);
      if (image.close) image.close();
      drawBlackboardIfNeeded(context, canvas);

      const blob = await canvasToBlob(canvas, "image/jpeg", PHOTO_JPEG_QUALITY);
      if (!blob) return new File([file], uploadFileName(file), { lastModified: uploadFileTime(file), type: file.type });

      return new File([blob], uploadFileName(file), {
        lastModified: uploadFileTime(file),
        type: "image/jpeg"
      });
    }

    async function compressedBackupImageFile(file) {
      if (!file || !file.type || !file.type.startsWith("image/")) return file;

      const image = await loadImage(file);
      const BACKUP_MAX_SIZE = 960;
      const BACKUP_JPEG_QUALITY = 0.75;
      const size = fittedImageSize(image.width, image.height, BACKUP_MAX_SIZE);
      const canvas = document.createElement("canvas");
      canvas.width = size.width;
      canvas.height = size.height;
      const context = canvas.getContext("2d");
      context.drawImage(image, 0, 0, size.width, size.height);
      if (image.close) image.close();

      const blob = await canvasToBlob(canvas, "image/jpeg", BACKUP_JPEG_QUALITY);
      if (!blob) throw new Error("backup failed");

      const originalName = uploadFileName(file);
      const backupName = originalName.replace(".jpg", "_original.jpg");

      return new File([blob], backupName, {
        lastModified: uploadFileTime(file),
        type: "image/jpeg"
      });
    }

    async function blackboardOverwriteFile(blob, fileName, config) {
      const sourceFile = new File([blob], fileName || "photo.jpg", {
        lastModified: Date.now(),
        type: blob.type || "image/jpeg"
      });
      const image = await loadImage(sourceFile);
      const size = fittedImageSize(image.width, image.height, PHOTO_MAX_SIZE);
      const canvas = document.createElement("canvas");
      canvas.width = size.width;
      canvas.height = size.height;
      const context = canvas.getContext("2d");
      context.drawImage(image, 0, 0, size.width, size.height);
      if (image.close) image.close();
      drawBlackboard(context, canvas, config);

      const result = await canvasToBlob(canvas, "image/jpeg", PHOTO_JPEG_QUALITY);
      if (!result) throw new Error("blackboard overwrite failed");

      return new File([result], fileName || uploadFileName(sourceFile), {
        lastModified: Date.now(),
        type: "image/jpeg"
      });
    }

    function bindBlackboardOverwriteButton(button) {
      if (button.dataset.blackboardOverwriteBound === "true") return;
      button.dataset.blackboardOverwriteBound = "true";
      button.addEventListener("click", function () {
        overwritePhotoBlackboard(button);
      });
    }

    async function overwritePhotoBlackboard(button) {
      if (!button || button.dataset.overwriting === "true") return;
      if (!guardBlackboardBeforePhoto()) return;
      if (!window.confirm("現在の電子黒板内容で、この写真の黒板を上書きします。元画像には戻せません。よろしいですか？")) return;

      button.dataset.overwriting = "true";
      button.disabled = true;
      uploadIndicator.show("黒板を修正中...", "既存写真へ黒板を再焼き付けしています");
      try {
        const response = await fetch(button.dataset.src, {
          credentials: "same-origin"
        });
        if (!response.ok) throw new Error("photo download failed");

        const blob = await response.blob();
        const config = blackboardOverwriteConfig(button);
        const file = await blackboardOverwriteFile(blob, button.dataset.fileName || "photo.jpg", config);
        const formData = new FormData();
        formData.append("_method", "patch");
        const token = csrfToken();
        if (token) formData.append("authenticity_token", token);
        formData.append("table_code", button.dataset.tableCode || "");
        formData.append("row_id", button.dataset.rowId || "");
        formData.append("file_column", button.dataset.fileColumn || "");
        formData.append("memo_column", button.dataset.memoColumn || "");
        formData.append("photo", file, file.name);

        const uploadResponse = await fetch(button.dataset.updateUrl, {
          body: formData,
          credentials: "same-origin",
          headers: { "X-Requested-With": "XMLHttpRequest" },
          method: "POST"
        });
        if (!uploadResponse.ok) throw new Error("photo overwrite upload failed");

        ensureBlackboardPhotoConfig(button, config);
        rememberElementScroll(button);
        window.location.href = uploadResponse.url || window.location.href;
      } catch (error) {
        uploadIndicator.hide();
        alert("黒板の上書き修正に失敗しました。通信状況を確認して、もう一度お試しください。");
        button.dataset.overwriting = "false";
        button.disabled = false;
      }
    }

    function drawBlackboardIfNeeded(context, canvas) {
      const config = currentBlackboardConfig();
      if (!config.enabled) return;

      drawBlackboard(context, canvas, config);
    }

    function currentBlackboardConfig() {
      const root = document.querySelector(".js-photo-blackboard-config");
      if (!root) return { enabled: false };

      const enabledInput = root.querySelector(".js-blackboard-enabled:checked");
      const positionInput = root.querySelector(".js-blackboard-position:checked");
      const values = {};
      root.querySelectorAll(".js-blackboard-field").forEach(function (input) {
        values[input.dataset.blackboardKey] = input.value || "";
      });
      if (Object.prototype.hasOwnProperty.call(values, "piles")) {
        values.piles = sanitizeBlackboardPilesValue(values.piles);
      }
      const scaleInput = root.querySelector(".js-blackboard-adjust[data-blackboard-key='scale']");
      const offsetXInput = root.querySelector(".js-blackboard-adjust[data-blackboard-key='offsetX']");
      const offsetYInput = root.querySelector(".js-blackboard-adjust[data-blackboard-key='offsetY']");

      return {
        enabled: !enabledInput || enabledInput.value === "1",
        position: positionInput ? positionInput.value : "left",
        scale: scaleInput ? numberInRange(scaleInput.value, 70, 140, 100) / 100 : 1,
        offsetX: offsetXInput ? numberInRange(offsetXInput.value, -120, 120, 0) : 0,
        offsetY: offsetYInput ? numberInRange(offsetYInput.value, -120, 120, 0) : 0,
        values: values
      };
    }

    function blackboardMissingRequiredPiles() {
      const config = currentBlackboardConfig();
      return !!(config.enabled && !(config.values && String(config.values.piles || "").trim()));
    }

    function guardBlackboardBeforePhoto(event) {
      if (!blackboardMissingRequiredPiles()) return true;

      if (event) {
        event.preventDefault();
        event.stopPropagation();
      }
      updateBlackboardRequiredHighlights();
      updateBlackboardPreview();
      refreshBlackboardPreviewSoon();

      const input = document.querySelector(".js-blackboard-field[data-blackboard-key='piles']");
      if (input) {
        input.focus({ preventScroll: true });
        input.scrollIntoView({ behavior: "smooth", block: "center" });
      }
      blackboardWarning.open(
        "施工明細が空白です",
        "施工明細を入力してから写真を撮影してください。\n例1）〇m*〇本 , 例2）◇m-◇本"
      );
      return false;
    }

    function blackboardOverwriteConfig(button) {
      const current = currentBlackboardConfig();
      const saved = blackboardPhotoConfig(button);
      const savedHasBurnedBoard = saved && saved.enabled !== false;
      const source = savedHasBurnedBoard ? saved : current;
      const currentScale = normalizedBlackboardScale(current.scale, BLACKBOARD_MIN_SCALE);
      const baseScale = savedHasBurnedBoard ? normalizedBlackboardScale(saved.scale, currentScale) : currentScale;
      const baseOffsetX = numericValue(source && source.offsetX, current.offsetX || 0);
      const baseOffsetY = numericValue(source && source.offsetY, current.offsetY || 0);
      return {
        enabled: true,
        position: (source && source.position) || current.position || "left",
        scale: normalizedBlackboardScale(baseScale * BLACKBOARD_OVERWRITE_SCALE, currentScale),
        offsetX: baseOffsetX,
        offsetY: baseOffsetY,
        values: current.values || {}
      };
    }

    function saveUploadedBlackboardPhotoConfig(form, formData) {
      const input = activeFileInput(form);
      if (!input) return;

      const uploaded = formData.get(input.name);
      if (!uploaded || !uploaded.name) return;

      const rowId = formData.get("row_id") || rowIdFromPhotoInput(input);
      const config = currentBlackboardConfig();
      writeBlackboardPhotoConfig({
        tableCode: formData.get("table_code") || "",
        rowId: rowId || "",
        fileName: uploaded.name,
        enabled: config.enabled,
        position: config.position || "left",
        scale: normalizedBlackboardScale(config.scale, 1),
        offsetX: config.offsetX || 0,
        offsetY: config.offsetY || 0,
        values: config.values || {},
        capturedAt: Date.now()
      });
    }

    function ensureBlackboardPhotoConfig(button, overwriteConfig) {
      if (blackboardPhotoConfig(button)) return;

      writeBlackboardPhotoConfig({
        tableCode: button.dataset.tableCode || "",
        rowId: button.dataset.rowId || "",
        fileName: button.dataset.fileName || "",
        enabled: true,
        position: overwriteConfig.position || "left",
        scale: normalizedBlackboardScale((overwriteConfig.scale || BLACKBOARD_OVERWRITE_SCALE) / BLACKBOARD_OVERWRITE_SCALE, BLACKBOARD_MIN_SCALE),
        offsetX: overwriteConfig.offsetX || 0,
        offsetY: overwriteConfig.offsetY || 0,
        values: overwriteConfig.values || {},
        capturedAt: Date.now()
      });
    }

    function blackboardPhotoConfig(button) {
      const storage = readBlackboardPhotoStorage();
      const tableCode = button.dataset.tableCode || "";
      const rowId = button.dataset.rowId || "";
      const fileName = button.dataset.fileName || "";
      return storage[blackboardPhotoKey(tableCode, rowId, fileName)] ||
        storage[blackboardPhotoKey(tableCode, "", fileName)] ||
        latestBlackboardPhotoConfig(storage, tableCode, fileName) ||
        null;
    }

    function writeBlackboardPhotoConfig(config) {
      if (!window.localStorage || !config.fileName) return;

      const storage = readBlackboardPhotoStorage();
      storage[blackboardPhotoKey(config.tableCode, config.rowId, config.fileName)] = config;
      if (!config.rowId) storage[blackboardPhotoKey(config.tableCode, "", config.fileName)] = config;
      try {
        localStorage.setItem(BLACKBOARD_PHOTO_STORAGE_KEY, JSON.stringify(storage));
      } catch (error) {
        // 保存できない環境でも撮影・アップロード自体は継続します。
      }
    }

    function readBlackboardPhotoStorage() {
      if (!window.localStorage) return {};

      try {
        return JSON.parse(localStorage.getItem(BLACKBOARD_PHOTO_STORAGE_KEY) || "{}") || {};
      } catch (error) {
        return {};
      }
    }

    function blackboardPhotoKey(tableCode, rowId, fileName) {
      return [tableCode || "", rowId || "", fileName || ""].join("::");
    }

    function latestBlackboardPhotoConfig(storage, tableCode, fileName) {
      let latestSameFile = null;
      let latest = null;
      Object.keys(storage || {}).forEach(function (key) {
        const config = storage[key];
        if (!config || config.enabled === false || config.tableCode !== tableCode) return;
        if (fileName && config.fileName === fileName && (!latestSameFile || numericValue(config.capturedAt, 0) > numericValue(latestSameFile.capturedAt, 0))) {
          latestSameFile = config;
        }
        if (!latest || numericValue(config.capturedAt, 0) > numericValue(latest.capturedAt, 0)) {
          latest = config;
        }
      });
      return latestSameFile || latest;
    }

    function rowIdFromPhotoInput(input) {
      const match = String(input.name || "").match(/table_rows\[([^\]]+)\]\[photo\]/);
      return match ? match[1] : "";
    }

    function numericValue(value, fallback) {
      const number = Number(value);
      return Number.isFinite(number) ? number : fallback;
    }

    function normalizedBlackboardScale(value, fallback) {
      let scale = numericValue(value, fallback);
      if (scale > 10) scale = scale / 100;
      if (!Number.isFinite(scale) || scale <= 0) scale = fallback;
      return Math.min(BLACKBOARD_MAX_SCALE, Math.max(BLACKBOARD_MIN_SCALE, scale));
    }

    function drawBlackboard(context, canvas, config) {
      const width = canvas.width;
      const height = canvas.height;
      const scale = normalizedBlackboardScale(config.scale, 1);
      const baseBoardWidth = Math.min(width * 0.45, Math.max(width * 0.39, 540));
      const minBoardWidth = Math.round(baseBoardWidth * 0.7);
      let boardWidth = Math.round(baseBoardWidth * scale);
      const maxOffset = Math.max(width, height);
      const offsetX = Math.round((config.offsetX || 0) / 120 * maxOffset * 0.08);
      const offsetY = Math.round((config.offsetY || 0) / 120 * maxOffset * 0.08);
      const headerRows = 5;
      const values = config.values || {};
      const labels = ["工事名", "工事年月日", "施工者", "工事場所", "施工明細"];
      const keys = ["project", "date", "maker", "place", "piles"];
      const missingPiles = !String(values.piles || "").trim();
      let metrics = blackboardMetrics(context, boardWidth, values, labels, keys);
      const maxBoardArea = width * height * 0.25;
      for (let i = 0; i < 5 && boardWidth * metrics.boardHeight > maxBoardArea && boardWidth > minBoardWidth; i += 1) {
        const areaRatio = Math.sqrt(maxBoardArea / (boardWidth * metrics.boardHeight));
        boardWidth = Math.max(minBoardWidth, Math.floor(boardWidth * areaRatio * 0.98));
        metrics = blackboardMetrics(context, boardWidth, values, labels, keys);
      }
      const lineWidth = metrics.lineWidth;
      const blankHeight = metrics.blankHeight;
      const footerHeight = metrics.footerHeight;
      const labelWidth = metrics.labelWidth;
      const kindWidth = metrics.kindWidth;
      const pad = metrics.pad;
      const labelFont = metrics.labelFont;
      const valueFont = metrics.valueFont;
      const footerFont = metrics.footerFont;
      const rowLayouts = metrics.rowLayouts;
      const rowsHeight = metrics.rowsHeight;
      const boardHeight = metrics.boardHeight;
      const baseX = config.position === "right" ? width - boardWidth : 0;
      const x = Math.max(0, Math.min(width - boardWidth, baseX + offsetX));
      const y = Math.max(0, Math.min(height - boardHeight, height - boardHeight + offsetY));

      context.save();
      context.fillStyle = missingPiles ? "#fee2e2" : "#fff";
      context.fillRect(x, y, boardWidth, boardHeight);
      if (missingPiles) {
        let pilesY = y;
        const pilesIndex = keys.indexOf("piles");
        rowLayouts.slice(0, pilesIndex).forEach(function (row) {
          pilesY += row.height;
        });
        context.fillStyle = "#fecaca";
        context.fillRect(x, pilesY, labelWidth, rowLayouts[pilesIndex].height);
        context.fillStyle = "#dc2626";
        context.fillRect(x + labelWidth, pilesY, boardWidth - labelWidth, rowLayouts[pilesIndex].height);
      }
      context.strokeStyle = missingPiles ? "#dc2626" : "#111";
      context.lineWidth = lineWidth;
      context.strokeRect(x, y, boardWidth, boardHeight);

      context.beginPath();
      let cursorY = y;
      rowLayouts.forEach(function (row, index) {
        cursorY += row.height;
        if (index < headerRows) {
          context.moveTo(x, cursorY);
          context.lineTo(x + boardWidth, cursorY);
        }
      });
      context.moveTo(x + labelWidth, y);
      context.lineTo(x + labelWidth, y + rowsHeight);
      context.stroke();

      cursorY = y;
      labels.forEach(function (label, index) {
        const rowHeight = rowLayouts[index].height;
        const rowY = cursorY;
        drawTextFit(context, label, x + pad, rowY + rowHeight * 0.66, labelWidth - pad * 2, labelFont, "bold");
        if (index === 0) {
          drawTextFitMultiline(context, values.project || "", x + labelWidth + pad, rowY, boardWidth - labelWidth - kindWidth - pad * 2, rowHeight, valueFont, "bold", "left", 2);
          drawTextFitMultiline(context, values.kind || "", x + boardWidth - kindWidth + pad, rowY, kindWidth - pad * 2, rowHeight, valueFont, "bold", "right", 1);
        } else {
          const isMissingPilesRow = missingPiles && keys[index] === "piles";
          drawTextFitMultiline(
            context,
            isMissingPilesRow ? "施工明細を入力してください" : (values[keys[index]] || ""),
            x + labelWidth + pad,
            rowY,
            boardWidth - labelWidth - pad * 2,
            rowHeight,
            valueFont,
            "bold",
            "left",
            index === 1 ? 1 : 2,
            isMissingPilesRow ? "#fff" : "#000"
          );
        }
        cursorY += rowHeight;
      });
      drawTextFit(
        context,
        values.footer || "",
        x + pad,
        y + boardHeight - footerHeight * 0.28,
        boardWidth - pad * 2,
        footerFont,
        "bold",
        "right"
      );
      context.restore();
    }

    function blackboardMetrics(context, boardWidth, values, labels, keys) {
      const dataRowHeight = Math.round(boardWidth * 0.09);
      const blankHeight = Math.round(boardWidth * 0.084);
      const footerHeight = Math.round(boardWidth * 0.09);
      const lineWidth = Math.max(2, Math.round(boardWidth / 260));
      const labelWidth = Math.round(boardWidth * 0.22);
      const kindWidth = Math.round(boardWidth * 0.30);
      const pad = Math.round(boardWidth * 0.012);
      const labelFont = Math.max(13, Math.round(dataRowHeight * 0.42) - 1);
      const valueFont = Math.max(12, Math.round(dataRowHeight * 0.40) - 1);
      const footerFont = Math.max(13, Math.round(footerHeight * 0.46) - 1);
      const rowLayouts = labels.map(function (_label, index) {
        const valueWidth = index === 0 ? boardWidth - labelWidth - kindWidth - pad * 2 : boardWidth - labelWidth - pad * 2;
        const projectLines = index === 0 ? textLineCount(context, values.project || "", valueWidth, valueFont, "bold", 2) : 1;
        const kindLines = index === 0 ? textLineCount(context, values.kind || "", kindWidth - pad * 2, valueFont, "bold", 1) : 1;
        const valueLines = index === 0 ? Math.max(projectLines, kindLines) : textLineCount(context, values[keys[index]] || "", valueWidth, valueFont, "bold", index === 1 ? 1 : 2);
        const lineHeight = Math.round(valueFont * 1.18);
        return {
          height: Math.max(dataRowHeight, valueLines * lineHeight + pad * 2),
          valueLines: valueLines
        };
      });
      const rowsHeight = rowLayouts.reduce(function (sum, row) { return sum + row.height; }, 0);
      const boardHeight = rowsHeight + blankHeight + footerHeight;

      return {
        blankHeight: blankHeight,
        boardHeight: boardHeight,
        footerFont: footerFont,
        footerHeight: footerHeight,
        kindWidth: kindWidth,
        labelFont: labelFont,
        labelWidth: labelWidth,
        lineWidth: lineWidth,
        pad: pad,
        rowLayouts: rowLayouts,
        rowsHeight: rowsHeight,
        valueFont: valueFont
      };
    }

    function drawTextFit(context, text, x, baselineY, maxWidth, fontSize, weight, align) {
      let size = fontSize;
      const safeText = String(text || "");
      context.textBaseline = "alphabetic";
      context.textAlign = align || "left";
      context.fillStyle = "#000";
      while (size > 8) {
        context.font = (weight || "normal") + " " + size + "px " + BLACKBOARD_FONT_FAMILY;
        if (context.measureText(safeText).width <= maxWidth) break;
        size -= 1;
      }
      context.save();
      context.beginPath();
      context.rect(x, baselineY - size * 1.15, maxWidth, size * 1.6);
      context.clip();
      context.fillText(safeText, align === "right" ? x + maxWidth : x, baselineY);
      context.restore();
    }

    function drawTextFitMultiline(context, text, x, y, maxWidth, maxHeight, fontSize, weight, align, maxLines, color) {
      let size = fontSize;
      let lines = [];
      const limit = maxLines || 2;
      const safeText = String(text || "");
      context.textBaseline = "alphabetic";
      context.textAlign = align || "left";
      context.fillStyle = color || "#000";
      while (size > 8) {
        context.font = (weight || "normal") + " " + size + "px " + BLACKBOARD_FONT_FAMILY;
        lines = wrapTextLines(context, safeText, maxWidth);
        const lineHeight = Math.round(size * 1.18);
        if (lines.length <= limit && lines.length * lineHeight <= maxHeight * 0.86) break;
        size -= 1;
      }
      context.font = (weight || "normal") + " " + size + "px " + BLACKBOARD_FONT_FAMILY;
      lines = wrapTextLines(context, safeText, maxWidth);
      if (lines.length > limit) {
        lines = lines.slice(0, limit);
        lines[limit - 1] = truncateTextLine(context, lines[limit - 1], maxWidth);
      }
      const lineHeight = Math.round(size * 1.18);
      const totalHeight = lines.length * lineHeight;
      const firstBaseline = y + Math.max(size, (maxHeight - totalHeight) / 2 + size);
      const textX = align === "right" ? x + maxWidth : x;

      context.save();
      context.beginPath();
      context.rect(x, y, maxWidth, maxHeight);
      context.clip();
      lines.forEach(function (line, index) {
        context.fillText(line, textX, firstBaseline + index * lineHeight);
      });
      context.restore();
    }

    function textLineCount(context, text, maxWidth, fontSize, weight, maxLines) {
      context.font = (weight || "normal") + " " + fontSize + "px " + BLACKBOARD_FONT_FAMILY;
      const lines = wrapTextLines(context, String(text || ""), maxWidth);
      return Math.max(1, Math.min(lines.length, maxLines || 1));
    }

    function wrapTextLines(context, text, maxWidth) {
      const safeText = String(text || "");
      if (!safeText) return [""];

      const lines = [];
      let line = "";
      Array.from(safeText).forEach(function (char) {
        const candidate = line + char;
        if (line && context.measureText(candidate).width > maxWidth) {
          lines.push(line);
          line = char;
        } else {
          line = candidate;
        }
      });
      lines.push(line);
      return lines;
    }

    function truncateTextLine(context, text, maxWidth) {
      let line = String(text || "");
      while (line.length > 0 && context.measureText(line + "…").width > maxWidth) {
        line = line.slice(0, -1);
      }
      return line ? line + "…" : "…";
    }

    function numberInRange(value, min, max, fallback) {
      const number = Number(value);
      if (!Number.isFinite(number)) return fallback;
      return Math.max(min, Math.min(max, number));
    }

    function bindBlackboardConfig() {
      const root = document.querySelector(".js-photo-blackboard-config");
      if (!root) return;

      root.querySelectorAll("input").forEach(function (input) {
        input.addEventListener("change", saveBlackboardConfig);
        input.addEventListener("input", saveBlackboardConfig);
      });
      const resetButton = root.querySelector(".js-blackboard-reset");
      if (resetButton) {
        resetButton.addEventListener("click", resetBlackboardFieldsToDefaults);
      }
      root.querySelectorAll(".js-blackboard-position").forEach(function (input) {
        input.addEventListener("change", function () {
          resetBlackboardOffsetToCorner(input.value);
        });
      });
    }

    function resetBlackboardOffsetToCorner(position) {
      const root = document.querySelector(".js-photo-blackboard-config");
      if (!root) return;

      const offsetXInput = root.querySelector(".js-blackboard-adjust[data-blackboard-key='offsetX']");
      const offsetYInput = root.querySelector(".js-blackboard-adjust[data-blackboard-key='offsetY']");
      if (offsetXInput) offsetXInput.value = position === "right" ? 120 : -120;
      if (offsetYInput) offsetYInput.value = 120;
      saveBlackboardConfig();
    }

    function saveBlackboardConfig() {
      const root = document.querySelector(".js-photo-blackboard-config");
      if (!root || !window.localStorage) return;

      const enabledInput = root.querySelector(".js-blackboard-enabled:checked");
      const positionInput = root.querySelector(".js-blackboard-position:checked");
      const data = {
        version: BLACKBOARD_CONFIG_VERSION,
        enabled: enabledInput ? enabledInput.value : "1",
        position: positionInput ? positionInput.value : "left",
        adjustments: {},
        fields: {}
      };
      root.querySelectorAll(".js-blackboard-field").forEach(function (input) {
        const key = input.dataset.blackboardKey;
        const value = normalizedBlackboardFieldValue(input);
        const defaultValue = normalizedBlackboardFieldDefault(input);
        if (value !== defaultValue) data.fields[key] = value;
      });
      root.querySelectorAll(".js-blackboard-adjust").forEach(function (input) {
        data.adjustments[input.dataset.blackboardKey] = input.value || "";
      });
      try {
        localStorage.setItem(BLACKBOARD_STORAGE_KEY, JSON.stringify(data));
      } catch (error) {
        // iPadのプライベートブラウズ等では保存できない場合がありますが、撮影処理は継続します。
      }
      updateBlackboardRequiredHighlights();
      updateBlackboardPreview();
    }

    function restoreBlackboardConfig() {
      const root = document.querySelector(".js-photo-blackboard-config");
      if (!root || !window.localStorage) return;

      let raw;
      try {
        raw = localStorage.getItem(BLACKBOARD_STORAGE_KEY);
      } catch (error) {
        return;
      }
      if (!raw) return;

      try {
        const data = JSON.parse(raw);
        root.querySelectorAll(".js-blackboard-enabled").forEach(function (input) {
          input.checked = input.value === data.enabled;
        });
        root.querySelectorAll(".js-blackboard-position").forEach(function (input) {
          input.checked = input.value === data.position;
        });
        Object.keys(data.fields || {}).forEach(function (key) {
          const input = root.querySelector(".js-blackboard-field[data-blackboard-key='" + key + "']");
          if (input) input.value = data.fields[key];
        });
        Object.keys(data.adjustments || {}).forEach(function (key) {
          const input = root.querySelector(".js-blackboard-adjust[data-blackboard-key='" + key + "']");
          if (input) {
            const savedValue = data.adjustments[key];
            input.value = key === "scale" && data.version !== BLACKBOARD_CONFIG_VERSION && savedValue === "100" ? BLACKBOARD_DEFAULT_SCALE_VALUE : savedValue;
          }
        });
      } catch (error) {
        try {
          localStorage.removeItem(BLACKBOARD_STORAGE_KEY);
        } catch (storageError) {
          // 保存領域に触れない環境では何もしません。
        }
      }
    }

    function sanitizeBlackboardPilesInput() {
      const root = document.querySelector(".js-photo-blackboard-config");
      if (!root) return;

      const input = root.querySelector(".js-blackboard-field[data-blackboard-key='piles']");
      if (input) input.value = sanitizeBlackboardPilesValue(input.value);
    }

    function updateBlackboardRequiredHighlights() {
      const root = document.querySelector(".js-photo-blackboard-config");
      if (!root) return;

      root.querySelectorAll(".js-blackboard-field").forEach(function (input) {
        const value = String(input.value || "").trim();
        const isCriticalEmpty = input.dataset.blackboardKey === "piles" && value.length === 0;
        input.classList.toggle("is-blackboard-empty", value.length === 0);
        input.classList.toggle("is-blackboard-critical-empty", isCriticalEmpty);
        if (input.dataset.blackboardKey === "date" && BLACKBOARD_STALE_DATE_CHECK) {
          input.classList.toggle("is-blackboard-stale-date", !blackboardDateHasTodayOrFuture(value));
        }
      });
    }

    function blackboardDateHasTodayOrFuture(value) {
      return blackboardDateCandidates(value).some(function (date) {
        return date.getTime() >= BLACKBOARD_TODAY.getTime();
      });
    }

    function blackboardDateCandidates(value) {
      const text = normalizeBlackboardDateText(value);
      const dates = [];
      let match;

      const monthDayPattern = /(?:(\d{4})\s*年\s*)?(\d{1,2})\s*月\s*(\d{1,2})\s*日?/g;
      while ((match = monthDayPattern.exec(text)) !== null) {
        addBlackboardDateCandidate(dates, match[1], match[2], match[3]);
      }

      const slashDatePattern = /(?:(\d{4})[\/.-])?(\d{1,2})[\/.-](\d{1,2})/g;
      while ((match = slashDatePattern.exec(text)) !== null) {
        addBlackboardDateCandidate(dates, match[1], match[2], match[3]);
      }

      const dayOnlyPattern = /(^|[^\d月])(\d{1,2})\s*日/g;
      while ((match = dayOnlyPattern.exec(text)) !== null) {
        addBlackboardDateCandidate(dates, null, BLACKBOARD_TODAY.getMonth() + 1, match[2]);
      }

      if (dates.length === 0) {
        const compactDatePattern = /(^|[^\d])(\d{1,4})(?=$|[^\d])/g;
        while ((match = compactDatePattern.exec(text)) !== null) {
          const numberText = match[2];
          if (numberText.length <= 2) {
            addBlackboardDateCandidate(dates, null, BLACKBOARD_TODAY.getMonth() + 1, numberText);
          } else {
            addBlackboardDateCandidate(dates, null, numberText.slice(0, -2), numberText.slice(-2));
          }
        }
      }

      return dates;
    }

    function normalizeBlackboardDateText(value) {
      return String(value || "").replace(/[０-９]/g, function (char) {
        return String.fromCharCode(char.charCodeAt(0) - 0xFEE0);
      }).replace(/[／．－]/g, function (char) {
        return { "／": "/", "．": ".", "－": "-" }[char] || char;
      });
    }

    function addBlackboardDateCandidate(dates, year, month, day) {
      const parsedYear = year == null || year === "" ? BLACKBOARD_TODAY.getFullYear() : numericValue(year, BLACKBOARD_TODAY.getFullYear());
      const parsedMonth = numericValue(month, 0);
      const parsedDay = numericValue(day, 0);
      if (parsedMonth < 1 || parsedMonth > 12 || parsedDay < 1 || parsedDay > 31) return;

      const date = new Date(parsedYear, parsedMonth - 1, parsedDay);
      if (date.getFullYear() !== parsedYear || date.getMonth() !== parsedMonth - 1 || date.getDate() !== parsedDay) return;

      dates.push(date);
    }

    function syncBlackboardFieldDefaults() {
      const root = document.querySelector(".js-photo-blackboard-config");
      if (!root) return;

      root.querySelectorAll(".js-blackboard-field").forEach(function (input) {
        input.dataset.blackboardDefault = normalizedBlackboardFieldDefault(input);
      });
    }

    function resetBlackboardFieldsToDefaults() {
      const root = document.querySelector(".js-photo-blackboard-config");
      if (!root) return;
      if (!window.confirm("電子黒板の入力内容をkintone初期値に戻します。よろしいですか？")) return;

      root.querySelectorAll(".js-blackboard-field").forEach(function (input) {
        input.value = normalizedBlackboardFieldDefault(input);
      });
      updateBlackboardRequiredHighlights();
      saveBlackboardConfig();
    }

    function normalizedBlackboardFieldValue(input) {
      const value = input.value || "";
      return input.dataset.blackboardKey === "piles" ? sanitizeBlackboardPilesValue(value) : value;
    }

    function normalizedBlackboardFieldDefault(input) {
      const fallback = input.dataset.blackboardDefault != null ? input.dataset.blackboardDefault : input.defaultValue;
      return input.dataset.blackboardKey === "piles" ? sanitizeBlackboardPilesValue(fallback) : (fallback || "");
    }

    function sanitizeBlackboardPilesValue(value) {
      let sanitized = String(value || "").replace(/[，]/g, ",").replace(/[★☆]/g, "").trim();
      sanitized = sanitized.replace(/\s+/g, " ");
      sanitized = sanitized.split(/[→⇒]/)[0] || "";
      sanitized = sanitized.replace(/[、,]\s*(?:JIS\b|H-?CPT|カーボン|キュア|.*材|.*追加|.*破損|.*折れ).*$/i, "");
      sanitized = sanitized.replace(/\s+(?:JIS\b|H-?CPT|カーボン|キュア|.*材).*$/i, "").trim();
      if (/推定|概算|未定|確認中|調整中|仮/.test(sanitized)) return "";
      return /[mMｍＭ]/.test(sanitized) ? sanitized : "";
    }

    function updateBlackboardPreview() {
      const canvas = document.querySelector(".js-blackboard-preview-canvas");
      if (!canvas) return;

      const context = canvas.getContext("2d");
      context.clearRect(0, 0, canvas.width, canvas.height);
      const gradient = context.createLinearGradient(0, 0, canvas.width, canvas.height);
      gradient.addColorStop(0, "#dbe3ee");
      gradient.addColorStop(0.52, "#f8fafc");
      gradient.addColorStop(1, "#cbd5e1");
      context.fillStyle = gradient;
      context.fillRect(0, 0, canvas.width, canvas.height);

      const config = currentBlackboardConfig();
      if (config.enabled) drawBlackboard(context, canvas, config);
    }

    function refreshBlackboardPreviewSoon() {
      if (!document.querySelector(".js-blackboard-preview-canvas")) return;

      [0, 80, 250, 700].forEach(function (delay) {
        window.setTimeout(function () {
          window.requestAnimationFrame(updateBlackboardPreview);
        }, delay);
      });
      if (document.fonts && document.fonts.ready) {
        document.fonts.ready.then(function () {
          updateBlackboardPreview();
        }).catch(function () {});
      }
    }

    function renamedOriginalFile(file) {
      return new File([file], uploadFileName(file), {
        lastModified: uploadFileTime(file),
        type: file.type || "image/jpeg"
      });
    }

    async function loadImage(file) {
      if (window.createImageBitmap) {
        try {
          return await createImageBitmap(file, { imageOrientation: "from-image" });
        } catch (error) {
          // Android端末によってはcreateImageBitmapが失敗するため、Image要素へフォールバックします。
        }
      }

      return new Promise(function (resolve, reject) {
        const url = URL.createObjectURL(file);
        const image = new Image();
        image.onload = function () {
          URL.revokeObjectURL(url);
          resolve(image);
        };
        image.onerror = function () {
          URL.revokeObjectURL(url);
          reject(new Error("image load failed"));
        };
        image.src = url;
      });
    }

    function fittedImageSize(width, height, maxSize) {
      const longest = Math.max(width, height);
      if (!longest || longest <= maxSize) return { width: width, height: height };

      const ratio = maxSize / longest;
      return {
        width: Math.round(width * ratio),
        height: Math.round(height * ratio)
      };
    }

    function canvasToBlob(canvas, type, quality) {
      return new Promise(function (resolve) {
        canvas.toBlob(resolve, type, quality);
      });
    }

    function uploadFileName(file) {
      const date = new Date(uploadFileTime(file));
      const stamp = [
        date.getFullYear(),
        pad2(date.getMonth() + 1),
        pad2(date.getDate()),
        "_",
        pad2(date.getHours()),
        pad2(date.getMinutes()),
        pad2(date.getSeconds())
      ].join("");
      return "photo_" + stamp + ".jpg";
    }

    function uploadFileTime(file) {
      return file && file.lastModified ? file.lastModified : Date.now();
    }

    function pad2(value) {
      return String(value).padStart(2, "0");
    }

    function csrfToken() {
      const meta = document.querySelector("meta[name='csrf-token']");
      return meta ? meta.content : "";
    }

    function handleFileInput(input) {
      syncFileChoice(input);
      if (!input.files || input.files.length === 0) return;
      if (!guardBlackboardBeforePhoto()) {
        input.value = "";
        syncFileChoice(input);
        pendingFileInput = null;
        return;
      }

      pendingFileInput = null;
      if (!input.classList.contains("js-photo-auto-submit")) return;

      const form = input.form;
      if (!form || form.dataset.uploading === "true") return;

      submitRememberingScroll(form);
    }

    function retryPendingFileInput() {
      if (!pendingFileInput) return;

      [300, 800, 1500].forEach(function (delay) {
        window.setTimeout(function () {
          if (pendingFileInput) handleFileInput(pendingFileInput);
        }, delay);
      });
    }

    function syncFileChoice(input) {
      const choice = input.closest(".js-photo-file-choice");
      if (!choice) return;

      choice.querySelectorAll("input[type='file']").forEach(function (otherInput) {
        if (otherInput !== input) otherInput.value = "";
      });

      const selectedFile = choice.querySelector(".js-photo-selected-file");
      if (!selectedFile) return;

      const file = input.files && input.files[0];
      clearUploadError(selectedFile);
      selectedFile.textContent = file ? file.name : "選択されていません";

      if (file && input.form) {
        lastSelectedFileInput = input;
        input.form.dataset.activeFileInput = input.id;
      }
    }

    function downloadLocalFile(file) {
      const url = URL.createObjectURL(file);
      const link = document.createElement("a");
      link.href = url;
      link.download = file.name || "photo.jpg";
      document.body.appendChild(link);
      link.click();
      link.remove();
      window.setTimeout(function () {
        URL.revokeObjectURL(url);
      }, 1000);
    }

    function buildUploadIndicator() {
      const overlay = document.createElement("div");
      overlay.className = "photo-upload-overlay hidden";
      overlay.setAttribute("role", "status");
      overlay.setAttribute("aria-live", "polite");
      overlay.innerHTML = [
        '<div class="photo-upload-dialog">',
        '  <div class="photo-upload-spinner" aria-hidden="true"></div>',
        '  <div class="photo-upload-message">アップロード中...</div>',
        '  <div class="photo-upload-submessage">保存完了までそのままお待ちください</div>',
        '  <div class="photo-upload-steps hidden" aria-hidden="true"></div>',
        '</div>'
      ].join("");
      document.body.appendChild(overlay);

      const message = overlay.querySelector(".photo-upload-message");
      const submessage = overlay.querySelector(".photo-upload-submessage");
      const stepsContainer = overlay.querySelector(".photo-upload-steps");

      function updateSteps(steps, activeStep) {
        if (!steps || !steps.length) {
          stepsContainer.replaceChildren();
          stepsContainer.classList.add("hidden");
          return;
        }

        const activeIndex = steps.findIndex(function (step) {
          return step.key === activeStep;
        });

        stepsContainer.replaceChildren();
        stepsContainer.classList.remove("hidden");
        steps.forEach(function (step, index) {
          const item = document.createElement("span");
          item.className = "photo-upload-step";
          if (activeIndex >= 0 && index < activeIndex) item.classList.add("is-complete");
          if (step.key === activeStep) item.classList.add("is-active");
          item.textContent = step.label;
          stepsContainer.appendChild(item);
        });
      }

      return {
        show: function (text, subtext, options) {
          message.textContent = text || "アップロード中...";
          submessage.textContent = subtext || "保存完了までそのままお待ちください";
          updateSteps(options && options.steps, options && options.activeStep);
          overlay.classList.remove("hidden");
        },
        hide: function () {
          overlay.classList.add("hidden");
        }
      };
    }

    function buildBlackboardWarningDialog() {
      const overlay = document.createElement("div");
      overlay.className = "blackboard-warning-overlay hidden";
      overlay.innerHTML = [
        '<div class="blackboard-warning-dialog" role="alertdialog" aria-modal="true" aria-labelledby="blackboard-warning-title" aria-describedby="blackboard-warning-message">',
        '  <div class="blackboard-warning-badge" aria-hidden="true">!</div>',
        '  <h2 id="blackboard-warning-title" class="blackboard-warning-title"></h2>',
        '  <p id="blackboard-warning-message" class="blackboard-warning-message"></p>',
        '  <button type="button" class="blackboard-warning-close">OK</button>',
        '</div>'
      ].join("");
      document.body.appendChild(overlay);

      const title = overlay.querySelector(".blackboard-warning-title");
      const message = overlay.querySelector(".blackboard-warning-message");
      const closeButton = overlay.querySelector(".blackboard-warning-close");
      let lastFocusedElement = null;

      function close() {
        overlay.classList.add("hidden");
        if (lastFocusedElement && typeof lastFocusedElement.focus === "function") {
          lastFocusedElement.focus({ preventScroll: true });
        }
      }

      closeButton.addEventListener("click", close);
      overlay.addEventListener("click", function (event) {
        if (event.target === overlay) close();
      });
      document.addEventListener("keydown", function (event) {
        if (event.key === "Escape" && !overlay.classList.contains("hidden")) close();
      });

      return {
        open: function (titleText, messageText) {
          lastFocusedElement = document.activeElement;
          title.textContent = titleText;
          message.textContent = messageText;
          overlay.classList.remove("hidden");
          closeButton.focus();
        }
      };
    }

    function buildDeleteConfirm() {
      const overlay = document.createElement("div");
      overlay.className = "delete-confirm-overlay hidden";
      overlay.innerHTML = [
        '<div class="delete-confirm-dialog" role="dialog" aria-modal="true">',
        '  <p class="delete-confirm-message"></p>',
        '  <div class="delete-confirm-actions">',
        '    <button type="button" class="btn delete-confirm-yes">はい</button>',
        '    <button type="button" class="btn delete-confirm-back">戻る</button>',
        '  </div>',
        '</div>'
      ].join("");
      document.body.appendChild(overlay);

      let targetForm = null;
      const message = overlay.querySelector(".delete-confirm-message");
      const yes = overlay.querySelector(".delete-confirm-yes");
      const back = overlay.querySelector(".delete-confirm-back");

      yes.addEventListener("click", function () {
        if (!targetForm) return;
        const form = targetForm;
        targetForm = null;
        overlay.classList.add("hidden");
        rememberPhotoScroll(form);
        form.submit();
      });
      back.addEventListener("click", function () {
        targetForm = null;
        overlay.classList.add("hidden");
      });
      overlay.addEventListener("click", function (event) {
        if (event.target === overlay) {
          targetForm = null;
          overlay.classList.add("hidden");
        }
      });

      return {
        open: function (form, text) {
          targetForm = form;
          message.textContent = text;
          overlay.classList.remove("hidden");
          back.focus();
        }
      };
    }

    function buildPhotoPreview() {
      const overlay = document.createElement("div");
      overlay.className = "photo-preview-overlay hidden";
      overlay.innerHTML = [
        '<div class="photo-preview-dialog" role="dialog" aria-modal="true" aria-label="写真プレビュー">',
        '  <div class="photo-preview-toolbar">',
        '    <div class="photo-preview-title"></div>',
        '    <button type="button" class="photo-preview-close">閉じる</button>',
        '  </div>',
        '  <div class="photo-preview-frame">',
        '    <img class="photo-preview-image" alt="">',
        '  </div>',
        '</div>'
      ].join("");
      document.body.appendChild(overlay);

      const image = overlay.querySelector(".photo-preview-image");
      const title = overlay.querySelector(".photo-preview-title");
      const closeButton = overlay.querySelector(".photo-preview-close");
      let open = false;
      let closingFromHistory = false;

      function close(pushHistoryBack) {
        if (!open) return;
        open = false;
        overlay.classList.add("hidden");
        image.removeAttribute("src");
        document.body.classList.remove("photo-preview-open");

        if (pushHistoryBack && history.state && history.state.photoPreview) {
          closingFromHistory = true;
          history.back();
        }
      }

      closeButton.addEventListener("click", function () {
        close(true);
      });

      overlay.addEventListener("click", function (event) {
        if (event.target === overlay) close(true);
      });

      document.addEventListener("keydown", function (event) {
        if (event.key === "Escape") close(true);
      });

      window.addEventListener("popstate", function () {
        if (closingFromHistory) {
          closingFromHistory = false;
          return;
        }
        close(false);
      });

      return {
        open: function (src, name) {
          if (!src) return;
          open = true;
          image.src = src;
          image.alt = name || "写真";
          title.textContent = name || "写真";
          document.body.classList.add("photo-preview-open");
          overlay.classList.remove("hidden");
          closeButton.focus();

          if (!history.state || !history.state.photoPreview) {
            history.pushState({ photoPreview: true }, "", window.location.href);
          }
        }
      };
    }
  });
