- weekdays = %w[日 月 火 水 木 金 土]

.photo-page
  .photo-header
    .photo-title
      = link_to "← 施工機一覧", machines_path
      %span.machine-title= @machine_name.presence || "施工機未指定"

  - if @photo_error
    .alert.alert-danger
      %strong 写真・物件情報を取得できませんでした。
      %pre= "#{@photo_error.class}: #{@photo_error.message}"

  .photo-date-tabs
    - @date_tabs.each do |date|
      - count = @records_by_date.fetch(date, []).count
      - incomplete_count = @records_by_date.fetch(date, []).count { |record| incomplete?(record) }
      - active = @selected_filter != "all" && date == @selected_date
      = link_to photos_path(machine: @machine_name, date: date), class: "photo-date-tab #{'active' if active}" do
        %span= "#{date.month}/#{date.day} #{weekdays[date.wday]}"
        .photo-tab-badges
          %strong= count
          - if active
            %strong= incomplete_count + @past_incomplete_records.count
    = link_to photos_path(machine: @machine_name, date: "all"), class: "photo-date-tab #{'active' if @selected_filter == 'all'}" do
      %span 全て
      .photo-tab-badges
        %strong= @default_records.count
        %strong= @incomplete_records.count

  - if @selected_records.present?
    .photo-records
      - @selected_records.each do |record|
        .photo-record
          .photo-record-main
            .photo-record-date
              = field_value(record, :date) || @selected_date
            .photo-record-site
              = record_title(record)
            - if record_address(record).present?
              .photo-record-address= "【#{record_address(record)}】"
            .photo-record-actions
              = link_to "地図", "javascript:undefined", class: "btn disabled"
              = link_to "図面", "javascript:undefined", class: "btn disabled"
              = link_to "設計資料", "javascript:undefined", class: "btn disabled"
              - if record_id(record).present?
                = link_to "写真", photo_path(record_id(record)), class: "btn primary"
              - else
                = link_to "写真", "javascript:undefined", class: "btn primary disabled"
              = link_to "管理", "javascript:undefined", class: "btn primary disabled"
          .photo-record-status
            %span
              写真：
              %strong= photo_status(record)
            %span
              管理：
              %strong= field_value(record, :management_status).presence || "未設定"
  - else
    .alert.alert-info
      = "#{@machine_name} に紐づく物件レコードが見つかりませんでした。"

  - if @field_keys.present?
    %details.photo-debug
      %summary 取得フィールド確認
      %p
        %strong フィールド:
        = @field_keys.join(", ")
      - if @field_preview.present?
        %table
          %tbody
            - @field_preview.first(30).each do |key, value|
              %tr
                %th= key
                %td= value
