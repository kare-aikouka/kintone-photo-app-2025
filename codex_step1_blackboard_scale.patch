+    function syncBlackboardScaleControl() {
+      const input = document.querySelector(".js-blackboard-adjust[data-blackboard-key='scale']");
+      const label = document.querySelector(".js-blackboard-scale-label");
+
+      if (!input) return;
+
+      const snapValue = function (value) {
+        const numericValue = Number(value);
+        const fallbackValue = Number(BLACKBOARD_DEFAULT_SCALE_VALUE);
+        const currentValue = Number.isFinite(numericValue) ? numericValue : fallbackValue;
+
+        return BLACKBOARD_SCALE_STEPS.reduce(function (nearest, step) {
+          return Math.abs(step - currentValue) < Math.abs(nearest - currentValue) ? step : nearest;
+        }, BLACKBOARD_SCALE_STEPS[0]);
+      };
+
+      const syncValueAndLabel = function () {
+        const scaleValue = snapValue(input.value);
+        input.value = scaleValue;
+
+        if (label) {
+          const scaleLabel = BLACKBOARD_SCALE_LABELS[scaleValue] || String(scaleValue);
+          label.textContent = scaleLabel + "（" + scaleValue + "%）";
+        }
+      };
+
+      input.min = BLACKBOARD_SCALE_STEPS[0];
+      input.max = BLACKBOARD_SCALE_STEPS[BLACKBOARD_SCALE_STEPS.length - 1];
+      syncValueAndLabel();
+      input.addEventListener("input", syncValueAndLabel);
+      input.addEventListener("change", syncValueAndLabel);
+    }
+
